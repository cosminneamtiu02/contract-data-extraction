# Worktrees (inherited convention)
.worktrees/
.claude/worktrees/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.hypothesis/

# Build artifacts
*.egg-info/
build/
dist/
*.egg

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
# extensions.json + settings.json are intentionally shared: the team standardises
# on the same VS Code extension set and on a workspace-pinned Python interpreter
# (.venv/bin/python) so first-run dev experience matches CI.
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Local environment
.env
.env.*
!.env.example

# Logs
*.log

# Additional tooling caches (preempt phase 2+)
.import_linter_cache/

# Model / data artifacts (preempt phase 2+ — Ollama weights are under ~/.ollama
# and outside the tree, but intermediate model files dropped into the working
# directory by Docling/RapidOCR/modelscope test runs would otherwise be a
# git-add-everything accident waiting to happen). Tracked test fixtures (sample
# PDFs, ground-truth CSVs) live under tests/fixtures/ which is NOT ignored —
# never under top-level data/ or models/, both of which are silently dropped.
*.gguf
*.safetensors
*.pt
*.pth
*.bin
models/
data/

# Claude Code per-machine state (transcripts, worktrees, etc.)
.claude/
