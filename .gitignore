# Worktrees (inherited convention)
.worktrees/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.hypothesis/

# Build artifacts
*.egg-info/
build/
dist/
*.egg

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
# Carve-outs for files that, once created and committed, must be tracked:
# the team will standardise on the same VS Code extension set and a
# workspace-pinned Python interpreter (.venv/bin/python) so first-run dev
# matches CI. The !-rules are inert until the files exist; a contributor
# who adds them must `git add` explicitly the first time (the negation
# only un-ignores; it does not auto-track).
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Local environment
.env
.env.*
# .env.example will be committed as a contributor template alongside the
# Settings env-var documentation (currently in src/extraction_service/settings.py
# docstring); the !-rule is a forward-looking stub with no current file behind it.
!.env.example

# Logs
*.log

# Additional tooling caches (preempt phase 2+)
.import_linter_cache/
# Jupyter creates this in-tree on first notebook open. .gitattributes already
# forward-declares *.ipynb LF-pinning for Phase 2+ OCR prototyping notebooks;
# this ignore-rule prevents the auto-created checkpoint sidecar from showing
# up in `git status` once a contributor first opens one.
.ipynb_checkpoints/

# Model / data artifacts (preempt phase 2+ — Ollama weights are under ~/.ollama
# and outside the tree, but intermediate model files dropped into the working
# directory by Docling/RapidOCR/modelscope test runs would otherwise be a
# git-add-everything accident waiting to happen). PDFs, CSVs, JSONs, and plain
# text files under tests/fixtures/ are NOT ignored, but the model-weight
# patterns below (*.bin, *.pt, *.pth, *.gguf, *.safetensors) DO match files
# inside tests/fixtures/ too — model-weight fixtures cannot be tracked there.
# Top-level data/ and models/ are also silently dropped.
*.gguf
*.safetensors
*.pt
*.pth
*.bin
models/
data/

# Claude Code per-machine state (transcripts, worktrees, etc.)
.claude/
