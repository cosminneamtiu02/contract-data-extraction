# Worktrees (inherited convention)
.worktrees/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
.hypothesis/

# Build artifacts
*.egg-info/
build/
dist/
*.egg

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
# Carve-outs (not yet created — these will be committed once added): the team
# will standardise on the same VS Code extension set and a workspace-pinned
# Python interpreter (.venv/bin/python) so first-run dev matches CI. Until
# then the !-rules are forward-looking stubs with no current file behind them.
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Local environment
.env
.env.*
# .env.example will be committed as a contributor template alongside the
# Settings env-var documentation (currently in src/extraction_service/settings.py
# docstring); the !-rule is a forward-looking stub with no current file behind it.
!.env.example

# Logs
*.log

# Additional tooling caches (preempt phase 2+)
.import_linter_cache/

# Model / data artifacts (preempt phase 2+ — Ollama weights are under ~/.ollama
# and outside the tree, but intermediate model files dropped into the working
# directory by Docling/RapidOCR/modelscope test runs would otherwise be a
# git-add-everything accident waiting to happen). PDFs, CSVs, JSONs, and plain
# text files under tests/fixtures/ are NOT ignored, but the model-weight
# patterns below (*.bin, *.pt, *.pth, *.gguf, *.safetensors) DO match files
# inside tests/fixtures/ too — model-weight fixtures cannot be tracked there.
# Top-level data/ and models/ are also silently dropped. Exception: see the
# `tests/ocr/data/` carve-out below — PDFs and .txt files there ARE ignored
# (privacy-sensitive contract samples) even though they live under `tests/`.
*.gguf
*.safetensors
*.pt
*.pth
*.bin
models/
data/

# Phase 2 OCR sample contracts — kept LOCAL ONLY (not committed to the public
# repo because the source PDFs are real-or-anonymised German legal contracts
# carrying privacy-sensitive content). The corresponding .txt ground-truth
# transcriptions are also ignored because they contain the same text. Tests in
# tests/ocr/test_docling_engine.py auto-skip when these files are not present,
# so CI on a fresh clone stays green. The .gitkeep keeps the directory tracked.
#
# The carve-out `!tests/ocr/data/` is needed because the broader `data/` rule
# above matches any directory named `data` at any depth. Order matters: the
# negation must come after the broader rule and before the file-level
# re-ignores below.
!tests/ocr/data/
tests/ocr/data/*.pdf
tests/ocr/data/*.txt
!tests/ocr/data/.gitkeep

# Claude Code per-machine state (transcripts, worktrees, etc.)
.claude/
