root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Lock TOML at 4-space indent even if the global default in [*] ever
# changes — the Python ecosystem (pyproject.toml, ruff.toml, etc.) is
# uniformly 4-space and we don't want a future [*] change to drift it.
[*.toml]
indent_size = 4

# Jupyter notebooks are JSON-serialised; align with the [*.{yml,yaml,json}]
# 2-space stanza above so a future notebook commit (e.g., a Phase 2 OCR
# prototyping sketch — .gitattributes already forward-declares *.ipynb
# LF-pinning for this scenario) doesn't drift to a 4-space JSON layout.
[*.ipynb]
indent_size = 2
