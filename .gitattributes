# Normalize line endings
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tiff binary
*.tif binary
*.pdf binary
*.onnx binary

# Tabular fixtures (text but should not be normalized aggressively).
*.csv text eol=lf
*.jsonl text eol=lf

# Lock files (collapse in PR diffs; tracked but not human-reviewed).
# `merge=union` reduces merge conflicts when two PRs add different deps —
# git takes the union of both sides instead of marking conflicts. The
# resulting file is then re-canonicalized by the lockfile-sync workflow.
uv.lock linguist-generated=true -diff merge=union
